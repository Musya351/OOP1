@startuml 1_DeteksiObjek_CollisionAvoidance

skinparam ActivityBackgroundColor #EAF2FF
skinparam ActivityBorderColor #2E5B9A
skinparam ActivityFontSize 12
skinparam ArrowColor #333333
skinparam ActivityDiamondBackgroundColor #F0EEFF
skinparam ActivityDiamondBorderColor #534AB7
skinparam ActivityStartColor #2E5B9A
skinparam ActivityEndColor #2E5B9A

title Activity Diagram – Deteksi Objek & Collision Avoidance

|#EAF2FF| AutopilotSystem |
start
:update() dipanggil setiap siklus;

|#F0EEFF| ObjectDetector |
:initialize() – cek sensor siap;

if (isReady() ?) then (Tidak)
  :Log error: sensor tidak siap;
  stop
else (Ya)
endif

:scan() – pindai area depan;
:Hasilkan List<DetectedObject>;

if (List kosong ?) then (Ya)
  |#EAF2FF| AutopilotSystem |
  :Tidak ada objek terdeteksi;
  :Lanjutkan mode CRUISE_CONTROL;
  stop
else (Tidak)
endif

:getNearestObject();
:getDistance() – ukur jarak objek terdekat;

|#EAF2FF| AutopilotSystem |
:Terima data DetectedObject;
:isObstacleAhead() = true;

if (isThreat = true ?) then (Ya)

  if (ObjectType ?) then (PEDESTRIAN)
    :Prioritas STOP – pejalan kaki;
    :mode = EMERGENCY_STOP;
    |#EAF2FF| Brake |
    :emergencyBrake();
    |#EAF2FF| Car |
    :stop();

  else if (ObjectType) then (VEHICLE)

    if (distance < minSafeDistance ?) then (Ya)
      :mode = EMERGENCY_STOP;
      |#EAF2FF| Brake |
      :emergencyBrake();
      |#EAF2FF| Car |
      :stop();

    else (Tidak – jarak masih aman)
      :mode = COLLISION_AVOIDANCE;
      |#EAF2FF| Brake |
      :apply() – rem bertahap;
      |#EAF2FF| Car |
      if (jalur kanan kosong ?) then (Ya)
        :turnRight();
      else (Tidak)
        :turnLeft();
      endif

    endif

  else if (ObjectType) then (OBSTACLE)
    :mode = COLLISION_AVOIDANCE;
    |#EAF2FF| Brake |
    :apply();
    |#EAF2FF| Car |
    :turnRight() atau turnLeft();

  else (TRAFFIC_SIGN / UNKNOWN)
    :mode = COLLISION_AVOIDANCE;
    |#EAF2FF| Brake |
    :apply() – perlambat kendaraan;

  endif

else (Tidak – bukan ancaman)
  |#EAF2FF| AutopilotSystem |
  :Monitor terus, tidak ada aksi;
endif

|#FFF0F5| ConsoleUI |
:displayAlert() – tampilkan peringatan;
:displayStatus() – update status layar;

|#EAF2FF| AutopilotSystem |
:getStatusReport();

stop

@enduml